<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      Title="{Loc 'firelock-bolt-control-window-title'}"
                      Resizable="False"
                      MinSize="240 480"
                      SetSize="240 480">
    <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">
        <controls:StripeBack Margin="0 0 0 10">
            <PanelContainer HorizontalExpand="True">
                <RichTextLabel Name="StatusLabel" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 6" />
            </PanelContainer>
        </controls:StripeBack>
        <PanelContainer StyleClasses="WindowBackground" VerticalExpand="True" HorizontalExpand="True" Margin="10 0 10 10">
            <LayoutContainer Name="LeverTrack" MinSize="128 320" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextureRect Name="TrackImage"
                             TexturePath="/Textures/_Funkystation/Interface/firelock_track.png"
                             MinSize="64 320"
                             Stretch="Scale" />
                <TextureRect Name="LeverHandle"
                             TexturePath="/Textures/_Funkystation/Interface/firelock_handle.png"
                             MinSize="128 64"
                             Stretch="Scale" />
            </LayoutContainer>
        </PanelContainer>
        <Label Name="HintLabel"
               Text="{Loc 'firelock-bolt-control-window-hint'}"
               HorizontalAlignment="Center"
               Align="Center"
               Margin="10 0 10 10"
               StyleClasses="DimNormal" />
        <PanelContainer StyleClasses="LowDivider" />
        <BoxContainer Orientation="Horizontal" Margin="10 4 10 4" VerticalAlignment="Bottom" HorizontalExpand="True">
            <Label Text="NT SECURE BYPASS-B" StyleClasses="WindowFooterText" />
            <Label Text="SYS-HYD.04" StyleClasses="WindowFooterText" HorizontalAlignment="Right" HorizontalExpand="True" Margin="0 0 5 0" />
            <TextureRect StyleClasses="NTLogoDark" Stretch="KeepAspectCentered" VerticalAlignment="Center" HorizontalAlignment="Right" SetSize="16 16"/>
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
